#!/bin/sh
# autowikipathy-hook : count commits; flag a grounding every commit_ratio commits.
# Pure POSIX sh, no dependencies (no jq/node). Never blocks the commit.
DIR="autowikipathy"; S="$DIR/.state"; K="$DIR/KNOBS.md"
[ -d "$DIR" ] || exit 0
mkdir -p "$S"
c=$(cat "$S/count" 2>/dev/null || echo 0)
case "$c" in ''|*[!0-9]*) c=0 ;; esac
c=$((c + 1))
r=$(grep -E '^[[:space:]]*commit_ratio:' "$K" 2>/dev/null | head -1 | sed -E 's/.*commit_ratio:[[:space:]]*([0-9]+).*/\1/')
case "$r" in ''|*[!0-9]*) r=3 ;; esac
if [ "$c" -ge "$r" ]; then
  : > "$S/DUE"
  c=0
fi
echo "$c" > "$S/count"
exit 0
